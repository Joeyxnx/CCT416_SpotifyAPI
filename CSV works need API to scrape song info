# AUDIO FEATURES
features = sp.audio_features(df["track_id"].tolist())
features_df = pd.DataFrame(features)

df = pd.concat([df, features_df[["danceability","energy","tempo","valence"]]], axis=1)

# TRACK DATA (popularity + artist IDs)
track_ids = df["track_id"].tolist()

tracks = []

for i in range(0, len(track_ids), 50):
    tracks.extend(sp.tracks(track_ids[i:i+50])["tracks"])

df["popularity"] = [track["popularity"] for track in tracks]

#Genre
genres = []

for track in tracks:
    artist_id = track["artists"][0]["id"]
    artist = sp.artist(artist_id)
    genres.append(", ".join(artist["genres"]))

df["genre"] = genres


